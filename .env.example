# ArwaPark - Environment Variables
# Copy this file to .env and fill in the values

# ─── Public (visible in browser) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_ENV=development

# ─── Server-only (never expose to browser) ───────────────────────────────────

# MongoDB connection string (Atlas or local)
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>"

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
